{
    "name": "crystallize-mcp-server",
    "version": "3.2.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:bridge": "bun run bin/dev-bridge.ts",
        "build": "vite build",
        "deploy": "vite build --mode production && wrangler deploy --config dist/crystallize_mcp_server/wrangler.json",
        "lint": "oxlint --fix",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@crystallize/js-api-client": "^7.2.0",
        "@crystallize/schema": "^6.12.0",
        "@modelcontextprotocol/ext-apps": "1.7.1",
        "@modelcontextprotocol/sdk": "1.28.0",
        "agents": "^0.8.7",
        "awilix": "^13.0.3",
        "fastest-levenshtein": "^1.0.16",
        "graphql": "^16.14.0",
        "hono": "^4.12.18",
        "jose": "^6.2.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.37.0",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.8.0",
        "oxlint": "^1.64.0",
        "tailwindcss": "^4.3.0",
        "typescript": "6.0.2",
        "vite": "^8.0.13",
        "vite-plugin-singlefile": "^2.3.3",
        "wrangler": "^4.91.0"
    },
    "overrides": {
        "@modelcontextprotocol/sdk": "1.28.0"
    },
    "trustedDependencies": [
        "core-js-pure",
        "esbuild",
        "sharp",
        "workerd"
    ]
}
