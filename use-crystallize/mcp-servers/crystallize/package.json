{
    "name": "crystallize-mcp-server",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "deploy": "vite build --mode production && wrangler deploy --config dist/crystallize_mcp_server/wrangler.json",
        "lint": "oxlint --fix",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@crystallize/js-api-client": "^5.3.0",
        "@crystallize/schema": "^6.11.0",
        "@modelcontextprotocol/sdk": "1.28.0",
        "agents": "^0.8.7",
        "awilix": "^13.0.3",
        "fastest-levenshtein": "^1.0.16",
        "graphql": "^16.13.2",
        "hono": "^4.12.14",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.33.1",
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.0",
        "oxlint": "^1.61.0",
        "tailwindcss": "^4.2.4",
        "typescript": "6.0.2",
        "vite": "^8.0.9",
        "wrangler": "^4.84.1"
    },
    "overrides": {
        "@modelcontextprotocol/sdk": "1.28.0"
    },
    "trustedDependencies": [
        "core-js-pure",
        "esbuild",
        "sharp",
        "workerd"
    ]
}
